# Supabase — required for مساعد بحر (chat). Copy to `.env` and fill in real values.
# See chatbot-handoff/docs/HANDOFF_شات_بوت_للفرونت.md

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key

# Tansiqy REST API (optional). Leave unset: local dev uses Vite proxy; production build uses https://tansiqy.runasp.net
# VITE_TANSIQY_API_URL=https://tansiqy.runasp.net
